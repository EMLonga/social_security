# Frontend Environment Variables

# API 基础 URL
VITE_API_BASE_URL=http://localhost:8000/api

# 应用名称
VITE_APP_NAME=Community Safety Alert

# 应用版本
VITE_APP_VERSION=1.0.0

# 地图配置（Leaflet）
VITE_MAP_CENTER_LAT=39.8283
VITE_MAP_CENTER_LNG=-98.5795
VITE_MAP_ZOOM_LEVEL=4

# 默认语言
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,zh

# 调试模式
VITE_DEBUG=false
